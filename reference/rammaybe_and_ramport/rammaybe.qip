set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "rammaybe_bb.v"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "rammaybe.inc"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "rammaybe.cmp"]
